{
  "lab": "lab5-i2c",
  "description": "I2C — DS1307 RTC",
  "target": "stm32f103c8",
  "capture_time": 20,
  "decoders": [
    "i2c:scl=D0:sda=D1",
    "uart:baudrate=115200:tx=D2:format=hex",
    "timing:data=D0"
  ],
  "register_checks": [
    {
      "id": "rc1",
      "name": "RCC_APB1ENR — I2C1 clock enabled",
      "points": 10,
      "address": "0x4002101C",
      "mask": "0x00200000",
      "expected": "0x00200000",
      "comment": "Bit 21 I2C1EN = 1"
    },
    {
      "id": "rc2",
      "name": "RCC_APB2ENR — GPIOB clock enabled",
      "points": 5,
      "address": "0x40021018",
      "mask": "0x00000008",
      "expected": "0x00000008",
      "comment": "Bit 3 IOPBEN = 1"
    },
    {
      "id": "rc3",
      "name": "GPIOB_CRL — PB6 va PB7 la AF_OD (0b1111)",
      "points": 10,
      "address": "0x40010C00",
      "mask": "0xFF000000",
      "expected": "0xFF000000",
      "comment": "PB6[27:24]=1111, PB7[31:28]=1111 — AF_OD 50MHz"
    },
    {
      "id": "rc4",
      "name": "I2C1_CR1 — PE=1 (peripheral enable)",
      "points": 15,
      "address": "0x40005400",
      "mask": "0x00000001",
      "expected": "0x00000001",
      "comment": "Bit 0 PE = 1"
    },
    {
      "id": "rc6",
      "name": "I2C1_CR2 — FREQ = 36 (36MHz APB1)",
      "points": 10,
      "address": "0x40005404",
      "mask": "0x0000003F",
      "expected": "0x00000024",
      "comment": "Bits[5:0] FREQ = 36 (0x24) — APB1 72MHz/2"
    },
    {
      "id": "rc7",
      "name": "I2C1_CCR — 100kHz Standard Mode (CCR=180, F/S=0)",
      "points": 10,
      "address": "0x4000541C",
      "mask": "0x000010FF",
      "expected": "0x000000B4",
      "comment": "F/S=0 (Sm), CCR=180 (0xB4) = 36MHz/2/100kHz"
    },
    {
      "id": "rc8",
      "name": "I2C1_TRISE — TRISE = 37",
      "points": 5,
      "address": "0x40005420",
      "mask": "0x0000003F",
      "expected": "0x00000025",
      "comment": "TRISE = FREQ+1 = 36+1 = 37 (0x25) cho 100kHz Sm"
    }
  ],
  "test_cases": [
    {
      "id": "tc1",
      "name": "Scan thay dia chi 0x68",
      "points": 30,
      "verify": {
        "source": "i2c",
        "type": "i2c_addr_ack",
        "addr": "68"
      }
    },
    {
      "id": "tc2",
      "name": "Set time thanh cong",
      "points": 35,
      "verify": {
        "source": "uart",
        "type": "contains",
        "value": "Set time:"
      }
    },
    {
      "id": "tc3",
      "name": "Doc RTC va in dung format qua UART",
      "points": 35,
      "verify": {
        "source": "uart",
        "type": "regex",
        "pattern": "Time: \\d{2}:\\d{2}:\\d{2}",
        "min_count": 3
      }
    }
  ]
}
