 295:Src/main.c    **** /* =======================================================
 296:Src/main.c    ****  *  DS1307 SET TIME
 297:Src/main.c    ****  *  Frame: [START][0x68+W][0x00][s][m][h][STOP]
 298:Src/main.c    ****  * ======================================================= */
 299:Src/main.c    **** void DS1307_SetTime(uint8_t h, uint8_t m, uint8_t s)
 300:Src/main.c    **** {
 301:Src/main.c    ****     if (!I2C_Start())
 302:Src/main.c    ****     {
 303:Src/main.c    ****         SendString("SetTime: START fail\n");
 304:Src/main.c    ****         return;
 305:Src/main.c    ****     }
 306:Src/main.c    ****     if (!I2C_SendAddr_Write(DS1307_ADDR))
 307:Src/main.c    ****     {
 308:Src/main.c    ****         I2C_Stop();
 309:Src/main.c    ****         SendString("SetTime: ADDR fail\n");
 310:Src/main.c    ****         return;
 311:Src/main.c    ****     }
 312:Src/main.c    **** 
 313:Src/main.c    ****     I2C_WriteByte(0x00);                   /* Register pointer: 0x00 (giay) */
 314:Src/main.c    ****     I2C_WriteByte(BCD_Encode(s) & 0x7F);  /* Giay — bit7=0: bat dao dong    */
 315:Src/main.c    ****     I2C_WriteByte(BCD_Encode(m));          /* Phut                           */
 316:Src/main.c    ****     I2C_WriteByte(BCD_Encode(h));          /* Gio — bit6=0: 24h mode         */
 317:Src/main.c    ****     I2C_Stop();
 318:Src/main.c    **** 
 319:Src/main.c    ****     SendString("Set time: ");
 320:Src/main.c    ****     SendNumber(h); SendChar(':');
 321:Src/main.c    ****     SendNumber(m); SendChar(':');
 322:Src/main.c    ****     SendNumber(s); SendChar('\n');
 323:Src/main.c    **** }
