  43:Src/main.c    ****     {
  44:Src/main.c    ****         SendString("ERROR: DS1307 not found!\n");
  45:Src/main.c    ****         while (1);
  46:Src/main.c    ****     }
  47:Src/main.c    **** 
  48:Src/main.c    ****     SendString("DS1307 found. Starting...\n");
  49:Src/main.c    **** 
  50:Src/main.c    ****     /* --- Set time 15:22:23 --- */
  51:Src/main.c    ****     DS1307_SetTime(15, 22, 23);
  52:Src/main.c    **** 
  53:Src/main.c    ****     /* --- Vong lap doc va in thoi gian --- */
  54:Src/main.c    ****     uint8_t h, m, s;
  55:Src/main.c    ****     while (1)
  56:Src/main.c    ****     {
  57:Src/main.c    ****         if (DS1307_ReadTime(&h, &m, &s))
  58:Src/main.c    ****         {
  59:Src/main.c    ****             SendString("Time: ");
  60:Src/main.c    ****             SendNumber(h); SendChar(':');
  61:Src/main.c    ****             SendNumber(m); SendChar(':');
  62:Src/main.c    ****             SendNumber(s); SendChar('\n');
  63:Src/main.c    ****         }
  64:Src/main.c    ****         else
  65:Src/main.c    ****         {
  66:Src/main.c    ****             SendString("Read error!\n");
  67:Src/main.c    ****         }
  68:Src/main.c    ****         delay_ms(1000);
  69:Src/main.c    ****     }
  70:Src/main.c    **** }
