  73:Src/main.c    **** /* =======================================================
  74:Src/main.c    ****  *  I2C SCAN — quet tu 0x01, gap ACK o dia chi target thi
  75:Src/main.c    ****  *  DUNG LUON, tra ve 1. Neu het 0x7F khong thay tra ve 0.
  76:Src/main.c    ****  *
  77:Src/main.c    ****  *  Moi dia chi:
  78:Src/main.c    ****  *    START → addr+W → cho ACK/NACK/timeout → STOP → next
  79:Src/main.c    ****  *  Neu ACK trung voi target → in "Found" → thoat ngay
  80:Src/main.c    ****  *  Neu ACK nhung khong phai target → in "Found (other)" → tiep tuc
  81:Src/main.c    ****  * ======================================================= */
  82:Src/main.c    **** uint8_t I2C_ScanUntilFound(uint8_t target)
  83:Src/main.c    **** {
  84:Src/main.c    ****     uint8_t  addr;
  85:Src/main.c    ****     uint8_t  ack_ok;
  86:Src/main.c    ****     volatile uint32_t t;
  87:Src/main.c    **** 
  88:Src/main.c    ****     SendString("Scanning I2C bus...\n");
  89:Src/main.c    **** 
ARM GAS  /tmp/cccyf4c6.s 			page 3


  90:Src/main.c    ****     for (addr = 0x01; addr <= 0x7F; addr++)
  91:Src/main.c    ****     {
  92:Src/main.c    ****         ack_ok = 0;
  93:Src/main.c    **** 
  94:Src/main.c    ****         /* Cho bus ranh; neu treo thi reset */
  95:Src/main.c    ****         t = SCAN_TIMEOUT;
  96:Src/main.c    ****         while (I2C_GetFlagStatus(I2C1, I2C_FLAG_BUSY))
  97:Src/main.c    ****         {
  98:Src/main.c    ****             if (--t == 0)
  99:Src/main.c    ****             {
 100:Src/main.c    ****                 I2C_SoftwareResetCmd(I2C1, ENABLE);
 101:Src/main.c    ****                 I2C_SoftwareResetCmd(I2C1, DISABLE);
 102:Src/main.c    ****                 I2C_Cmd(I2C1, ENABLE);
 103:Src/main.c    ****                 break;
 104:Src/main.c    ****             }
 105:Src/main.c    ****         }
 106:Src/main.c    **** 
 107:Src/main.c    ****         /* Tao START */
 108:Src/main.c    ****         I2C_GenerateSTART(I2C1, ENABLE);
 109:Src/main.c    ****         t = SCAN_TIMEOUT;
 110:Src/main.c    ****         while (!I2C_CheckEvent(I2C1, I2C_EVENT_MASTER_MODE_SELECT))
 111:Src/main.c    ****         {
 112:Src/main.c    ****             if (--t == 0) break;
 113:Src/main.c    ****         }
 114:Src/main.c    **** 
 115:Src/main.c    ****         /* Gui dia chi neu START ok */
 116:Src/main.c    ****         if (t > 0)
 117:Src/main.c    ****         {
 118:Src/main.c    ****             I2C_Send7bitAddress(I2C1, addr << 1, I2C_Direction_Transmitter);
 119:Src/main.c    **** 
 120:Src/main.c    ****             t = SCAN_TIMEOUT;
 121:Src/main.c    ****             while (t > 0)
 122:Src/main.c    ****             {
 123:Src/main.c    ****                 if (I2C_CheckEvent(I2C1, I2C_EVENT_MASTER_TRANSMITTER_MODE_SELECTED))
 124:Src/main.c    ****                 {
 125:Src/main.c    ****                     ack_ok = 1;
 126:Src/main.c    ****                     break;
 127:Src/main.c    ****                 }
 128:Src/main.c    ****                 if (I2C_GetFlagStatus(I2C1, I2C_FLAG_AF))
 129:Src/main.c    ****                 {
 130:Src/main.c    ****                     I2C_ClearFlag(I2C1, I2C_FLAG_AF);
 131:Src/main.c    ****                     break;
 132:Src/main.c    ****                 }
 133:Src/main.c    ****                 --t;
 134:Src/main.c    ****             }
 135:Src/main.c    ****         }
 136:Src/main.c    **** 
 137:Src/main.c    ****         /* Luon STOP de giai phong bus */
 138:Src/main.c    ****         I2C_GenerateSTOP(I2C1, ENABLE);
 139:Src/main.c    **** 
 140:Src/main.c    ****         /* Cho STOP hoan thanh */
 141:Src/main.c    ****         t = SCAN_TIMEOUT;
 142:Src/main.c    ****         while (I2C_GetFlagStatus(I2C1, I2C_FLAG_BUSY))
 143:Src/main.c    ****         {
 144:Src/main.c    ****             if (--t == 0)
 145:Src/main.c    ****             {
 146:Src/main.c    ****                 I2C_SoftwareResetCmd(I2C1, ENABLE);
ARM GAS  /tmp/cccyf4c6.s 			page 4


 147:Src/main.c    ****                 I2C_SoftwareResetCmd(I2C1, DISABLE);
 148:Src/main.c    ****                 I2C_Cmd(I2C1, ENABLE);
 149:Src/main.c    ****                 break;
 150:Src/main.c    ****             }
 151:Src/main.c    ****         }
 152:Src/main.c    **** 
 153:Src/main.c    ****         /* Xu ly ket qua cua dia chi nay */
 154:Src/main.c    ****         if (ack_ok)
 155:Src/main.c    ****         {
 156:Src/main.c    ****             SendString("Found: 0x");
 157:Src/main.c    ****             SendHex(addr);
 158:Src/main.c    ****             SendChar('\n');
 159:Src/main.c    **** 
 160:Src/main.c    ****             if (addr == target)
 161:Src/main.c    ****             {
 162:Src/main.c    ****                 /* Dung luon — day chinh la thiet bi can tim */
 163:Src/main.c    ****                 return 1;
 164:Src/main.c    ****             }
 165:Src/main.c    ****             /* Neu ACK nhung khong phai target: in va scan tiep */
 166:Src/main.c    ****         }
 167:Src/main.c    ****     }
 168:Src/main.c    **** 
 169:Src/main.c    ****     /* Het dia chi ma khong thay target */
 170:Src/main.c    ****     return 0;
 171:Src/main.c    **** }
