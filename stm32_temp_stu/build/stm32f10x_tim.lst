 971:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (NewState != DISABLE)
 972:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 973:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Enable the DMA sources */
