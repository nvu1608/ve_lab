 146:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   * @param  CANx:           where x can be 1 or 2 to to select the CAN 
ARM GAS  /tmp/cctOO46K.s 			page 4


 147:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   *                         peripheral.
 148:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   * @param  CAN_InitStruct: pointer to a CAN_InitTypeDef structure that
 149:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   *                         contains the configuration information for the 
 150:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   *                         CAN peripheral.
 151:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   * @retval Constant indicates initialization succeed which will be 
 152:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   *         CAN_InitStatus_Failed or CAN_InitStatus_Success.
 153:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   */
 154:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** uint8_t CAN_Init(CAN_TypeDef* CANx, CAN_InitTypeDef* CAN_InitStruct)
 155:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** {
 156:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   uint8_t InitStatus = CAN_InitStatus_Failed;
 157:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   uint32_t wait_ack = 0x00000000;
 158:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   /* Check the parameters */
 159:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_CAN_ALL_PERIPH(CANx));
 160:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_FUNCTIONAL_STATE(CAN_InitStruct->CAN_TTCM));
 161:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_FUNCTIONAL_STATE(CAN_InitStruct->CAN_ABOM));
 162:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_FUNCTIONAL_STATE(CAN_InitStruct->CAN_AWUM));
 163:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_FUNCTIONAL_STATE(CAN_InitStruct->CAN_NART));
 164:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_FUNCTIONAL_STATE(CAN_InitStruct->CAN_RFLM));
 165:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_FUNCTIONAL_STATE(CAN_InitStruct->CAN_TXFP));
 166:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_CAN_MODE(CAN_InitStruct->CAN_Mode));
 167:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_CAN_SJW(CAN_InitStruct->CAN_SJW));
 168:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_CAN_BS1(CAN_InitStruct->CAN_BS1));
 169:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_CAN_BS2(CAN_InitStruct->CAN_BS2));
 170:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_CAN_PRESCALER(CAN_InitStruct->CAN_Prescaler));
 171:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** 
 172:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   /* Exit from sleep mode */
 173:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   CANx->MCR &= (~(uint32_t)CAN_MCR_SLEEP);
 174:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** 
 175:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   /* Request initialisation */
 176:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   CANx->MCR |= CAN_MCR_INRQ ;
 177:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** 
 178:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   /* Wait the acknowledge */
 179:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   while (((CANx->MSR & CAN_MSR_INAK) != CAN_MSR_INAK) && (wait_ack != INAK_TIMEOUT))
 180:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   {
 181:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     wait_ack++;
 182:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   }
 183:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** 
 184:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   /* Check acknowledge */
