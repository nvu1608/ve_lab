 117:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** /**
 118:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   * @brief  Deinitializes the CAN peripheral registers to their default reset values.
 119:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   * @param  CANx: where x can be 1 or 2 to select the CAN peripheral.
 120:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   * @retval None.
 121:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   */
 122:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** void CAN_DeInit(CAN_TypeDef* CANx)
 123:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** {
 124:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   /* Check the parameters */
 125:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   assert_param(IS_CAN_ALL_PERIPH(CANx));
 126:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****  
 127:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   if (CANx == CAN1)
 128:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   {
 129:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     /* Enable CAN1 reset state */
 130:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_CAN1, ENABLE);
 131:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     /* Release CAN1 from reset state */
 132:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_CAN1, DISABLE);
 133:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   }
 134:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   else
 135:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   {  
 136:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     /* Enable CAN2 reset state */
 137:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_CAN2, ENABLE);
 138:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     /* Release CAN2 from reset state */
 139:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_CAN2, DISABLE);
 140:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c ****   }
 141:Drivers/STM32F10x_StdPeriph_Driver/src/stm32f10x_can.c **** }
